{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://status.userland.run/schema/feature.schema.json",
  "title": "userland.run feature registry entry",
  "description": "One feature in registry/features/*.yaml. IDs are immutable; rename via superseded_by.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "area", "status"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(\\.[a-z0-9-]+)+$",
      "description": "Immutable dotted id: area.group.name[.sub]"
    },
    "title": { "type": "string", "minLength": 1 },
    "area": { "type": "string", "description": "Must exist in areas.yaml" },
    "status": {
      "enum": ["planned", "in-progress", "shipped", "partial", "deprecated"]
    },
    "level": {
      "enum": ["specified", "implemented", "tested", "conformant"],
      "description": "Only on areas with leveled:true"
    },
    "syscall": { "type": "integer", "description": "Optional RISC-V syscall number" },
    "spec": { "type": "string", "description": "Free-text pointer (repo doc, spec section, issue)" },
    "since": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" },
    "notes": { "type": "string", "description": "Required when status is partial" },
    "superseded_by": {
      "type": ["string", "null"],
      "description": "If set, references the id that replaces this one"
    }
  }
}

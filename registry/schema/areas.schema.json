{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://status.userland.run/schema/areas.schema.json",
  "title": "userland.run area taxonomy",
  "type": "object",
  "additionalProperties": false,
  "required": ["contract", "levels", "areas"],
  "properties": {
    "contract": { "const": 1 },
    "levels": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Ordered conformance ladder for leveled areas"
    },
    "areas": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "owner", "repo"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "title": { "type": "string" },
          "owner": { "type": "string" },
          "repo": { "type": "string" },
          "leveled": { "type": "boolean" },
          "blurb": { "type": "string" }
        }
      }
    }
  }
}
